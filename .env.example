# ─── Dirac Solver — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Node.js server port
NODE_ENV=development
PORT=3001

# MCP (Octopus) server — Docker container on port 8000
OCTOPUS_MCP_URL=http://localhost:8000

# Local Python fallback engine — backend_engine/main.py on port 8001
LOCAL_ENGINE_URL=http://localhost:8001

# VisIt headless renderer — bare "visit" if on PATH, or full absolute path
# Windows example: D:\Softwares_new\VisIt\LLNL\VisIt3.4.2\visit.exe
# Linux example:   /usr/local/visit/bin/visit
VISIT_EXE=visit

# Workspace root — absolute path to the Dirac_solver repo on this host
# Windows example: E:\PostGraduate\Dirac_solver
# Linux example:   /home/ubuntu/Dirac_solver
WORKSPACE_ROOT=/home/ubuntu/Dirac_solver

# Octopus output directory — where Octopus writes results (also Docker volume mount target)
# Windows example: E:\PostGraduate\Dirac_solver\@Octopus_docs\output
# Linux  example:  /home/ubuntu/Dirac_solver/@Octopus_docs/output
OCTOPUS_OUTPUT_DIR=/home/ubuntu/Dirac_solver/@Octopus_docs/output

# LLM API credentials (for AI physics explanation feature)
ZCHAT_API_KEY=your_key_here
ZCHAT_BASE_URL=https://zchat.example.com/v1
