{
  "version": "2026-04-01",
  "workflow": "supervisor_planner_executor_reviewer",
  "protocol": {
    "version": "v1",
    "harness_scope": "universal_tri_agent",
    "harness_principle": "Planner/Executor/Reviewer adapt to user intent (development, KB construction, validation, UI review) and iterate until reviewer gate passes.",
    "sync_state_file": "state/dirac_solver_progress_sync.json",
    "allowed_phases": [
      "RECEIVED",
      "PLANNED",
      "EXECUTING",
      "REVIEWING",
      "REPLAN",
      "ESCALATING",
      "DONE",
      "BLOCKED"
    ],
    "required_evidence": [
      "changed_files",
      "verification_steps",
      "artifact_paths"
    ]
  },
  "roles": {
    "supervisor": {
      "skill_id": "dirac.supervisor.v1",
      "purpose": "Own natural-language task intake, route role handoff, enforce iteration budget, and trigger escalation when blocked.",
      "required_outputs": [
        "task_id",
        "session_id",
        "intent_type",
        "owner_role",
        "phase",
        "iteration.current",
        "iteration.max",
        "next_action"
      ],
      "handoff_to": "planner"
    },
    "planner": {
      "skill_id": "dirac.planner.v1",
      "purpose": "Translate user goal into executable plan with dynamic decomposition (feature dev, KB construction, validation matrix, and iteration budget).",
      "required_outputs": [
        "selected_case",
        "threshold",
        "max_iterations",
        "openclaw_planner.ok",
        "execution_budget.retry_budget",
        "execution_budget.timeout_seconds",
        "workflow.stage_order",
        "workflow.main_controls",
        "review_plan.benchmark_delta_required"
      ],
      "handoff_to": "executor"
    },
    "executor": {
      "skill_id": "dirac.executor.v1",
      "purpose": "Execute planned workstreams (harness/Octopus/KB ingestion/UI checks) with endpoint fallback and auditable outputs.",
      "required_outputs": [
        "execution_mode",
        "simple_harness.passed",
        "simple_harness.best_relative_error",
        "mcp.attempted",
        "octopus.passed",
        "benchmark_review.final_verdict",
        "benchmark_review.delta.relative_error",
        "benchmark_review.next_action",
        "blocked.is_blocked",
        "blocked.reason_code"
      ],
      "handoff_to": "reviewer"
    },
    "reviewer": {
      "skill_id": "dirac.reviewer.v1",
      "purpose": "Gate release by TDDFT physics accuracy versus classic Octopus cases, knowledge retrieval quality, UI aesthetics/usability readiness, and skill contract completion.",
      "required_outputs": [
        "checks.accuracy_ok",
        "checks.benchmarks_aligned_ok",
        "checks.kb_richness_ok",
        "checks.retrieval_skill_ok",
        "checks.web_evidence_ok",
        "checks.mcp_attempted_ok",
        "checks.octopus_ok",
        "checks.ui_ok",
        "checks.ui_rendering_ok",
        "checks.skills_contracts_ok",
        "checks.openclaw_flow_ok",
        "checks.planner_executor_chain_ok",
        "checks.deep_model_priority_ok",
        "checks.logs_consistent",
        "checks.execution_ok",
        "retrieval.skill_invoked",
        "repair_type",
        "repair_confidence",
        "final_verdict"
      ],
      "handoff_to": "planner"
    }
  },
  "contracts": {
    "handoff_packet": {
      "required_fields": [
        "handoff_id",
        "task_id",
        "from_role",
        "to_role",
        "goal",
        "constraints",
        "acceptance_criteria",
        "required_inputs",
        "required_outputs",
        "risk_level"
      ]
    },
    "escalation_packet": {
      "required_fields": [
        "escalation_id",
        "task_id",
        "from_role",
        "to_role",
        "blocker_type",
        "severity",
        "attempted",
        "needs_external.provider",
        "needs_external.ask",
        "evidence"
      ],
      "auto_trigger_when": [
        "same_error_no_progress_for_2_iterations",
        "missing_required_permissions",
        "external_service_unreachable",
        "reviewer_fail_same_root_cause_twice"
      ]
    },
    "review_verdict": {
      "required_fields": [
        "review_id",
        "task_id",
        "final_verdict",
        "checks.accuracy_ok",
        "checks.benchmarks_aligned_ok",
        "checks.execution_ok",
        "checks.logs_consistent",
        "checks.ui_rendering_ok",
        "checks.skills_contracts_ok",
        "repair_type",
        "repair_confidence",
        "findings",
        "required_fixes",
        "evidence"
      ],
      "pass_condition": "all_checks_true_and_evidence_present"
    }
  }
}
