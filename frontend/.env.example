# ─── Dirac Solver Frontend — Environment Variables ───────────────────────────
# Copy to frontend/.env.local and fill in your values.
# frontend/.env.local is gitignored — never commit it.
# Mode defaults:
# - .env.development => VITE_ENABLE_DEVFLOW=true
# - .env.production  => VITE_ENABLE_DEVFLOW=false

# Node.js API server base URL (no trailing slash)
# Cloud example: http://47.121.196.105:3001
VITE_API_BASE_URL=http://localhost:3001

# Octopus MCP server base URL (no trailing slash)
# Cloud example: http://47.121.196.105:8000
VITE_MCP_BASE_URL=http://localhost:8000

# DevFlow dashboard visibility (default hidden)
VITE_ENABLE_DEVFLOW=false
